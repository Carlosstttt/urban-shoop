<Detalle>:
    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Detalle"
            elevation: 0
            md_bg_color: 0.10, 0.10, 0.13, 1
            left_action_items: [["arrow-left", lambda x: root.regresar()]]
            right_action_items: [["heart-outline", lambda x: root.alternar_favorito(x)]]

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: "16dp"
                spacing: "18dp"

                # ── Imagen del producto ───────────────────────────────────
                MDCard:
                    size_hint_y: None
                    height: "240dp"
                    radius: [20]
                    elevation: 2
                    md_bg_color: 0.14, 0.14, 0.17, 1

                    Image:
                        id: producto_imagen
                        source: "assets/camisa casual.jpg"
                        allow_stretch: True
                        keep_ratio: True
                        padding: "10dp"

                # ── Info básica ───────────────────────────────────────────
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: "6dp"

                    MDLabel:
                        id: txt_titulo
                        text: "Nombre Producto"
                        font_style: "H5"
                        bold: True
                        adaptive_height: True

                    MDLabel:
                        id: txt_precio
                        text: "$0.00"
                        font_style: "H5"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.primary_color
                        bold: True
                        adaptive_height: True

                    MDLabel:
                        id: txt_descripcion
                        text: "Descripción del producto."
                        theme_text_color: "Secondary"
                        font_style: "Body2"
                        adaptive_height: True

                MDSeparator:

                # ── Selector de talla ─────────────────────────────────────
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: "10dp"

                    MDLabel:
                        text: "Talla"
                        bold: True
                        font_style: "Subtitle1"
                        adaptive_height: True

                    MDBoxLayout:
                        orientation: "horizontal"
                        adaptive_height: True
                        spacing: "8dp"

                        MDRoundFlatButton:
                            id: btn_xs
                            text: "XS"
                            size_hint_x: None
                            width: "46dp"
                            on_release: root.seleccionar_talla_por_indice(0)

                        MDRoundFlatButton:
                            id: btn_s
                            text: "S"
                            size_hint_x: None
                            width: "46dp"
                            on_release: root.seleccionar_talla_por_indice(1)

                        MDRoundFlatButton:
                            id: btn_m
                            text: "M"
                            size_hint_x: None
                            width: "46dp"
                            on_release: root.seleccionar_talla_por_indice(2)

                        MDRoundFlatButton:
                            id: btn_l
                            text: "L"
                            size_hint_x: None
                            width: "46dp"
                            on_release: root.seleccionar_talla_por_indice(3)

                        MDRoundFlatButton:
                            id: btn_xl
                            text: "XL"
                            size_hint_x: None
                            width: "46dp"
                            on_release: root.seleccionar_talla_por_indice(4)

                    # ── NUEVA SECCIÓN DE CENTÍMETROS DINÁMICOS ──────────────────
                    MDLabel:
                        text: root.texto_cm
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 0.7
                        font_style: "Caption"
                        bold: True
                        size_hint_y: None
                        height: self.texture_size[1] if root.texto_cm != "" else 0
                        padding: ["4dp", "2dp"]

                MDSeparator:

                # ── Selector de cantidad ──────────────────────────────────
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: "10dp"

                    MDLabel:
                        text: "Cantidad"
                        bold: True
                        font_style: "Subtitle1"
                        adaptive_height: True

                    MDBoxLayout:
                        orientation: "horizontal"
                        adaptive_height: True
                        spacing: "0dp"
                        size_hint_x: None
                        width: "140dp"

                        MDIconButton:
                            icon: "minus-circle-outline"
                            user_font_size: "32sp"
                            on_release: root.cambiar_cantidad(-1)
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.primary_color

                        MDLabel:
                            id: txt_cantidad
                            text: "1"
                            font_style: "H6"
                            halign: "center"
                            adaptive_height: True
                            size_hint_x: None
                            width: "40dp"

                        MDIconButton:
                            icon: "plus-circle-outline"
                            user_font_size: "32sp"
                            on_release: root.cambiar_cantidad(1)
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.primary_color

                # ── Botón agregar ─────────────────────────────────────────
                MDRaisedButton:
                    text: "  AGREGAR AL CARRITO"
                    icon: "cart-plus"
                    size_hint_x: 1
                    height: "52dp"
                    font_style: "Button"
                    elevation: 3
                    on_release: root.agregar_al_carrito()